# rpa_server.env

# API 인증 키 (Action/Report 엔드포인트 호출 시 X-API-Key 헤더에 포함)
API_KEY             = 31fa97967ca0089aa2956b40c3ec1886009d9ba1c248dbb26e1132d701e3eb76

# 서버 설정
SERVER_HOST         = 0.0.0.0
SERVER_PORT         = 8000

# AL 서버
MY_COMPUTER_IP      = 172.28.10.206  # ipconfig로 확인한 본인 IP
SERVER_NAME         = Alabama #1 RPA Server

# GA 서버
#MY_COMPUTER_IP      = 172.28.10.206  # ipconfig로 확인한 본인 IP
#SERVER_NAME         = Georgia #1 RPA Server

# 타임존 설정 (미국 중부 시간: America/Chicago)
APP_TIMEZONE        = America/Chicago
#APP_TIMEZONE       = America/New_York


# 실행 모드: test: Fail 작업만 테스트(2분 간격 순차 실행) / prod = JOB_AL/GA 절대 시간 사용 / testall: 모든 작업 테스트
SERVER_MODE         = prod
#SERVER_MODE        = test
#SERVER_MODE        = testall

# 리포트 View URL
REPORT_ALDEV_URL    = https://gmesdev-mcaal.hlmando.com/reportservice/reportviewer.jsp
REPORT_GADEV_URL    = https://gmesdev-mcaga.hlmando.com/reportservice/reportviewer.jsp
REPORT_ALPROD_URL   = https://gmes30-mcaal.hlmando.com/reportservice/reportviewer.jsp
REPORT_GAPROD_URL   = https://gmes30-mcaga.hlmando.com/reportservice/reportviewer.jsp

####### 자동화 스케줄 설정 - 시작 #######

# Job 정의 (형식: 이름:요일:시:분:스크립트경로)
# 요일: mon-fri / tue-sat 등, 매월 N일: dom-N
JOB_SILENT          = TRANS
JOB_AL="
    LPA5S:mon-fri:08:00:rpa_tasks/lpa_5s/lpa_5s_combined_sender.py
    PRINT_A:mon-fri:15:35:rpa_tasks/dailyprintout/daily_printout_automail.py
    PRINT_B:mon-fri:23:35:rpa_tasks/dailyprintout/daily_printout_automail.py
    PRINT_C:tue-sat:08:35:rpa_tasks/dailyprintout/daily_printout_automail.py
    DBSINK:mon-sat:05:00:rpa_tasks/dailyprintout/db_sink_prod_to_dev.py
    TRANS:dom-2:06:00:rpa_tasks/transportation/transportation_rpa.exe
    "
JOB_GA="
    SPO_HOLD:mon-fri:08:00:rpa_tasks/lpa_5s/lpa_5s_combined_sender.py
    "

####### 자동화 스케줄 설정 - 종료 #######

