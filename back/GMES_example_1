def switch_to_frame_with_element(driver, by, locator, timeout=10):
    """주어진 locator를 포함한 iframe을 찾아 그 iframe으로 switch."""
    wait = WebDriverWait(driver, timeout)

    driver.switch_to.default_content()
    iframes = driver.find_elements(By.TAG_NAME, "iframe")
    print("iframe 개수:", len(iframes))

    for idx, frame in enumerate(iframes):
        driver.switch_to.default_content()
        driver.switch_to.frame(frame)
        try:
            wait.until(ec.presence_of_element_located((by, locator)))
            print(f">>> 이 프레임에서 {locator} 찾음! index = {idx}")
            return idx  # 필요한 경우 인덱스를 저장해서 재사용 가능
        except Exception:
            continue

    raise Exception(f"어느 iframe에서도 요소 {locator} 를 찾지 못했습니다.")


def find_in_any_frame(driver, by, locator, timeout=10):
    """여러 iframe 중 해당 요소를 포함한 프레임을 찾아 진입 후 요소 반환."""
    driver.switch_to.default_content()
    iframes = driver.find_elements(By.TAG_NAME, "iframe")
    wait = WebDriverWait(driver, timeout)

    for frame in iframes:
        driver.switch_to.default_content()
        driver.switch_to.frame(frame)
        try:
            elem = wait.until(ec.presence_of_element_located((by, locator)))
            return elem
        except Exception:
            continue

    raise Exception(f"어느 iframe에서도 요소 {locator} 를 찾지 못했습니다.")


def wait_for_new_file(download_dir, timeout=60):
    """현재 시점 이후 새로 생긴 파일이 나타날 때까지 대기."""
    folder = Path(download_dir)
    before = {f.name for f in folder.glob("*")}

    for _ in range(timeout):
        time.sleep(1)
        after = {f.name for f in folder.glob("*")}
        new_files = after - before
        # .crdownload / .part 같은 임시 파일은 제외
        new_files = {f for f in new_files if not f.endswith((".crdownload", ".part"))}
        if new_files:
            # 가장 최근 파일 하나만 리턴
            latest = max(new_files, key=lambda n: (folder / n).stat().st_mtime)
            return str(folder / latest)

    raise TimeoutError("다운로드 파일을 찾지 못했습니다.")


