# 환경변수
# (private repo이므로 .env 파일 포함)

# Python 캐시
**/__pycache__/
__pycache__/
*.py[cod]
*.pyo

# PyInstaller 산출물 (Option A로 전환 시 사용)
build/
dist/
*.spec

# 로그
Logs/
*.log

# 다운로드 임시 파일
Download/

# 산출물 (RPA 출력 파일)
output/
*.xls
*.xlsx
*.exe
*.zip

# IDE
.vscode/
.idea/

# 가상환경
venv/
.venv/

# operation 폴더 - 파일 제외, 폴더 구조(.gitkeep)만 유지
operation/**
!operation/**/
!operation/**/.gitkeep
